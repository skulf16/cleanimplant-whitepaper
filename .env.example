# ── Basis-URL (für absolute Download-Links in der E-Mail) ──
# In Produktion auf die echte Domain setzen, z. B. https://whitepaper.cleanimplant.org
NEXT_PUBLIC_BASE_URL=

# ── Signatur-Schlüssel für die geschützten Download-Links (PFLICHT in Produktion) ──
# Beliebige lange Zufallszeichenkette, z. B. mit:  openssl rand -base64 32
DOWNLOAD_SECRET=

# ── SMTP (Versand der Download-Mail) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Optionaler Absender (Name + Adresse). Fällt sonst auf SMTP_USER zurück.
SMTP_FROM=CleanImplant Foundation <info@cleanimplant.org>

# ── CleverReach (Newsletter + Double-Opt-in) ──
CLEVERREACH_CLIENT_ID=
CLEVERREACH_CLIENT_SECRET=
# Gruppe für deutsche Anmeldungen (Pflicht), optional separate EN-Gruppe
CLEVERREACH_GROUP_ID=
CLEVERREACH_GROUP_ID_EN=
# Double-Opt-in-Formular-IDs (für die DOI-Bestätigungsmail)
CLEVERREACH_FORM_ID=
CLEVERREACH_FORM_ID_EN=
